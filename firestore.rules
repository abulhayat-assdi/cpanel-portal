rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /* =====================================================
       🔐 HELPER FUNCTIONS (GLOBAL)
    ====================================================== */

    function isAuth() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuth() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    /* =====================================================
       🔐 INTERNAL PORTAL COLLECTIONS
       (Login required)
    ====================================================== */

    // Teachers Directory
    match /teachers/{docId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // Users (Auth profiles & roles)
    match /users/{userId} {
      allow read: if isAuth();
      allow write: if isAdmin() || request.auth.uid == userId;
    }

    // Classes
    match /classes/{classId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAdmin() ||
        (isAuth() && resource.data.teacherUid == request.auth.uid);
      allow delete: if isAdmin();
    }

    // Class Routines
    match /class_routines/{routineId} {
      allow read, write: if isAuth();
    }

    // Class Schedules
    match /class_schedules/{scheduleId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // Resources Library
    match /resources/{resourceId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // Batch Info
    match /batch_info/{docId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // Notices
    match /notices/{noticeId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // Policies
    match /policies/{docId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // Meeting Minutes
    match /meeting_minutes/{docId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    /* =====================================================
       📩 FEEDBACK SYSTEM
       (Public submit + Admin approval)
    ====================================================== */

    match /feedback/{feedbackId} {
      // Public can submit feedback
      allow create: if true;

      // Admin can read everything
      // Public can read only APPROVED feedback
      allow read: if isAdmin() || resource.data.status == 'APPROVED';

      // Only admin can approve / delete
      allow update, delete: if isAdmin();
    }

    /* =====================================================
       🌐 PUBLIC WEBSITE COLLECTIONS
       (No login required for read)
    ====================================================== */

    // Blog Comments (Public read, write, update for likes/replies)
    match /blogComments/{commentId} {
      allow read, create, update: if true;
      allow delete: if isAdmin();
    }

    // Blog Posts
    match /blog_posts/{postId} {
      allow read: if resource.data.status == "published";
      allow create, update, delete: if isAdmin();
    }

    // Posts (Legacy blog collection)
    match /posts/{postId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Instructors (Public view)
    match /instructors/{docId} {
      allow read: if resource.data.active == true;
      allow create, update, delete: if isAdmin();
    }

    // Course Modules
    match /course_modules/{docId} {
      allow read: if resource.data.active == true;
      allow create, update, delete: if isAdmin();
    }

    // Success Stories: Video Testimonials
    match /successVideos/{videoId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // Success Stories: Written Reviews
    match /successReviews/{reviewId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    /* =====================================================
       📩 CONTACT FORM (PUBLIC)
    ====================================================== */

    match /contact_inquiries/{docId} {
      // Public can submit contact form
      allow create: if true;

      // Only admin can read & manage
      allow read, update: if isAdmin();
      allow delete: if false;
    }

    /* =====================================================
       🛠️ SYSTEM / ACTIVITY LOGS
    ====================================================== */

    match /activity_logs/{logId} {
      allow create: if isAuth();
      allow read: if isAdmin();
    }

    /* =====================================================
       🚫 DEFAULT DENY (SECURITY NET)
    ====================================================== */

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
