rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /* =====================================================
       🔐 HELPER FUNCTIONS (GLOBAL)
    ====================================================== */

    function isAuth() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuth() && 
        request.auth.token.role == 'admin';
    }

    function isTeacher() {
      return isAuth() && 
        request.auth.token.role == 'teacher';
    }

    /* =====================================================
       🔐 INTERNAL PORTAL COLLECTIONS
       (Login required)
    ====================================================== */

    // Teachers Directory
    match /teachers/{docId} {
      allow read: if isAuth();
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || (isAuth() && request.auth.token.email.lower() == resource.data.email.lower());
    }

    // Users (Auth profiles & roles)
    match /users/{userId} {
      allow read: if isAuth() && (request.auth.uid == userId || isAdmin() || isTeacher());
      // Users can create their own profile but cannot give themselves 'admin' role
      allow create: if isAdmin() || (request.auth.uid == userId && request.resource.data.role != 'admin');
      // Users can update their profile but cannot modify the 'role' field
      allow update: if isAdmin() || (
        request.auth.uid == userId && 
        (!('role' in request.resource.data) || request.resource.data.role == resource.data.role)
      );
      // ✅ Users cannot delete their own profile — protects homework records
      //    and activity logs from orphaning. Only admins may hard-delete.
      allow delete: if isAdmin();
    }

    // Classes
    match /classes/{classId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAdmin() ||
        (isAuth() && resource.data.teacherUid == request.auth.uid);
      allow delete: if isAdmin();
    }

    // Class Routines
    match /class_routines/{routineId} {
      // ✅ All authenticated users can view the schedule
      allow read: if isAuth();
      // ✅ Only admins can create, edit, or delete routines
      allow write: if isAdmin();
    }

    // Class Schedules
    match /class_schedules/{scheduleId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // Resources Library
    match /resources/{resourceId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // Batch Info
    match /batch_info/{docId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // Batches (Dynamic Batch Mapping)
    match /batches/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }


    // Notices
    match /notices/{noticeId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // Policies
    match /policies/{docId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // Meeting Minutes
    match /meeting_minutes/{docId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // Daily Tracker Reports
    match /daily_tracker_reports/{docId} {
      allow create: if true; // Public can submit reports
      allow read, delete: if isAdmin(); // Only admins can view and delete
    }

    // Student Profile Updates
    match /student_profile_updates/{docId} {
      allow read: if isAuth();
      // Students can only create updates tagged with their own UID
      allow create: if isAuth() && 
                    request.resource.data.studentUid == request.auth.uid &&
                    request.resource.data.updateReason.size() < 1000;
      // Only the owning student or an admin can update/delete
      allow update, delete: if isAdmin() || (isAuth() && request.auth.uid == resource.data.studentUid);
    }

    // Public Batch Students list for registration
    match /public_batch_students/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Exam Results
    match /exam_results/{docId} {
      allow read: if isAuth() && (resource.data.studentUid == request.auth.uid || isAdmin() || isTeacher());
      allow write: if isAdmin();
    }

    // Student Notices — only teachers and admins can create/edit/delete
    match /student_notices/{docId} {
      allow read: if true; // Students read before login; also shown in dashboard
      allow write: if isAdmin() || isTeacher();
    }

    // Student Contact Messages - students create, admins read/manage
    match /contact_messages/{docId} {
      allow create: if isAuth() && 
                    request.resource.data.message.size() < 2000 &&
                    request.resource.data.subject.size() < 200;
      allow read, update, delete: if isAdmin();
    }

    // Module Resources - teachers upload for their own module, admin manages all
    match /module_resources/{docId} {
      // ✅ All authenticated users can read resources
      allow read: if isAuth();
      // ✅ Only teachers/admins can create; teacher must own the resource
      allow create: if (isTeacher() || isAdmin()) &&
        request.resource.data.teacherUid == request.auth.uid;
      // ✅ Owner teacher or admin can update/delete
      allow update, delete: if isAdmin() || (
        isTeacher() && resource.data.teacherUid == request.auth.uid
      );
    }

    // Homework Submissions — Students create (owner-only), all auth read, admin/system deletes
    match /homework_submissions/{docId} {
      allow create: if isAuth() && 
                    request.resource.data.studentUid == request.auth.uid &&
                    request.resource.data.homeworkUrl.size() < 500;
      allow read: if isAuth() && (resource.data.studentUid == request.auth.uid || isAdmin() || isTeacher());
      allow update: if false; // Homework cannot be edited once submitted
      // Only owner or admin can delete
      allow delete: if isAdmin() || (isAuth() && request.auth.uid == resource.data.studentUid);
    }

    /* =====================================================
       📩 FEEDBACK SYSTEM
       (Public submit + Admin approval)
    ====================================================== */

    match /feedback/{feedbackId} {
      // Public can submit feedback
      allow create: if request.resource.data.feedback.size() < 2000 &&
                    request.resource.data.studentName.size() < 100 &&
                    request.resource.data.status == 'PENDING';

      // Admin can read everything
      // Public can read only APPROVED feedback
      allow read: if isAdmin() || resource.data.status == 'APPROVED';

      // Only admin can approve / delete
      allow update, delete: if isAdmin();
    }

    /* =====================================================
       🌐 PUBLIC WEBSITE COLLECTIONS
       (No login required for read)
    ====================================================== */

    // Blog Comments (Public read, write, update for likes/replies)
    match /blogComments/{commentId} {
      // Anyone can read and create comments
      allow read, create: if request.resource.data.content.size() < 1000 &&
                            request.resource.data.userName.size() < 100;
      // Anyone can update, but ONLY the 'likes' and 'replies' fields
      allow update: if request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes', 'replies']) &&
                    (request.resource.data.likes >= resource.data.likes);
      allow delete: if isAdmin();
    }

    // Blog Posts
    match /blog_posts/{postId} {
      allow read: if resource.data.status == "published";
      allow create, update, delete: if isAdmin();
    }

    // Posts (Legacy blog collection)
    match /posts/{postId} {
      // Only published posts are public, admins can read drafts
      allow read: if resource.data.status == 'published' || isAdmin();
      allow write: if isAdmin();
    }

    // Instructors (Public view)
    match /instructors/{docId} {
      allow read: if resource.data.active == true;
      allow create, update, delete: if isAdmin();
    }

    // Course Modules
    match /course_modules/{docId} {
      allow read: if resource.data.active == true || isAuth();
      allow create, update, delete: if isAdmin();
    }

    // Success Stories: Video Testimonials
    match /successVideos/{videoId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // Success Stories: Written Reviews
    match /successReviews/{reviewId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    /* =====================================================
       📩 CONTACT FORM (PUBLIC)
    ====================================================== */

    match /contact_inquiries/{docId} {
      // Public can submit contact form
      allow create: if request.resource.data.message.size() < 3000 &&
                    request.resource.data.email.size() < 100 &&
                    request.resource.data.name.size() < 100;

      // Only admin can read & manage
      allow read, update: if isAdmin();
      allow delete: if false;
    }

    /* =====================================================
       🛠️ SYSTEM / ACTIVITY LOGS
    ====================================================== */

    match /activity_logs/{logId} {
      allow create: if isTeacher() || isAdmin();
      allow read: if isAdmin();
    }

    // Public Pages (CMS Content)
    match /public_pages/{pageId} {
      allow read: if true;
      allow write: if isAuth() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    /* =====================================================
       🚫 DEFAULT DENY (SECURITY NET)
    ====================================================== */

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
